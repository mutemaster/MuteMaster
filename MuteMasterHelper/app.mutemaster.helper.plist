<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd plist for the privileged helper, embedded at
  MuteMaster.app/Contents/Library/LaunchDaemons/app.mutemaster.helper.plist
  and registered by the app via SMAppService.daemon(plistName:).

  • BundleProgram          : helper executable, path relative to the app bundle root.
  • MachServices           : the XPC service the app connects to (.privileged).
  • AssociatedBundleIdentifiers : ties the daemon's lifecycle/approval to our app.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>app.mutemaster.helper</string>
    <key>BundleProgram</key>
    <string>Contents/MacOS/MuteMasterHelper</string>
    <key>MachServices</key>
    <dict>
        <key>app.mutemaster.helper</key>
        <true/>
    </dict>
    <key>AssociatedBundleIdentifiers</key>
    <array>
        <string>app.mutemaster</string>
    </array>
</dict>
</plist>
